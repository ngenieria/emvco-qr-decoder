{
  "name": "ngenieria/emvco-qr-decoder",
  "description": "EMVCo Merchant Presented QR Code Decoder - Bre-B Compatible",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "ngenieria",
      "role": "Lead Architect"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-gd": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.9",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "lint": "phpcs --standard=PSR12 app/ tests/",
    "analyze": "phpstan analyze app/ --level=9"
  }
}
